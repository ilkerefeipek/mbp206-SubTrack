@inherits LayoutComponentBase

<div class="min-h-screen bg-slate-50 flex">
    <AuthorizeView>
        <Authorized>
            <Sidebar />
            <div class="flex-1 flex flex-col min-w-0">
                <TopBar />
                <main class="flex-1 p-6 lg:p-8 overflow-y-auto">@Body</main>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="flex-1">@Body</div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<ToastContainer />
