<header class="bg-white border-b border-slate-200 h-16 px-6 flex items-center gap-4">
    <button class="lg:hidden text-slate-600 hover:text-slate-900 transition focus:outline-none focus-visible:ring-2 ring-primary/40 rounded p-1"
            aria-label="Menüyü aç" @onclick="ToggleMobileMenu">
        <Icon Name="menu" Class="w-6 h-6" />
    </button>

    <div class="hidden md:flex flex-1 max-w-md relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
            <Icon Name="search" Class="w-4 h-4" />
        </span>
        <input type="search"
               placeholder="Abonelik ara..."
               class="w-full pl-9 pr-3 py-2 text-sm bg-slate-50 border border-slate-200 rounded-lg text-slate-900 placeholder:text-slate-400 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus:bg-white" />
    </div>

    <div class="flex-1 md:hidden"></div>

    <div class="flex items-center gap-2">
        <button class="relative p-2 text-slate-600 hover:text-slate-900 transition rounded-lg hover:bg-slate-100 focus:outline-none focus-visible:ring-2 ring-primary/40"
                aria-label="Bildirimler">
            <Icon Name="bell" Class="w-5 h-5" />
            @if (UnreadCount > 0)
            {
                <span class="absolute top-1 right-1 w-4 h-4 text-[10px] font-bold rounded-full bg-danger text-white flex items-center justify-center">@UnreadCount</span>
            }
        </button>
        <UserMenu />
    </div>
</header>

@code {
    [Parameter] public int UnreadCount { get; set; }
    [Parameter] public EventCallback OnToggleMobileMenu { get; set; }

    private Task ToggleMobileMenu() => OnToggleMobileMenu.InvokeAsync();
}
