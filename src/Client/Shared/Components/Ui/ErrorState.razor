<div class="flex flex-col items-center justify-center text-center py-12 px-6">
    <div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center text-danger mb-4">
        <Icon Name="alert-circle" Class="w-7 h-7" />
    </div>
    <h3 class="text-lg font-semibold text-slate-900 mb-1">@Title</h3>
    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="text-sm text-slate-500 max-w-md">@Description</p>
    }
    @if (OnRetry.HasDelegate)
    {
        <div class="mt-6">
            <Button Variant="Button.ButtonVariant.Secondary" OnClick="OnRetry">Tekrar dene</Button>
        </div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Bir hata olustu";
    [Parameter] public string? Description { get; set; }
    [Parameter] public EventCallback OnRetry { get; set; }
}
