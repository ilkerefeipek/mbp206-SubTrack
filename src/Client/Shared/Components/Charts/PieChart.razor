@using ApexCharts

<div class="w-full">
    @if (!string.IsNullOrEmpty(Title))
    {
        <h3 class="text-sm font-semibold text-slate-700 mb-2">@Title</h3>
    }
    <ApexChart TItem="ChartSlice" Options="_options" Width="@Width">
        <ApexPointSeries TItem="ChartSlice"
                         Items="Data"
                         Name="series"
                         SeriesType="@(Donut ? SeriesType.Donut : SeriesType.Pie)"
                         XValue="@(e => e.Label)"
                         YValue="@(e => e.Value)" />
    </ApexChart>
</div>

@code {
    public sealed record ChartSlice(string Label, decimal Value);

    [Parameter, EditorRequired] public IEnumerable<ChartSlice> Data { get; set; } = Array.Empty<ChartSlice>();
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool Donut { get; set; }
    [Parameter] public string Width { get; set; } = "100%";

    private ApexChartOptions<ChartSlice> _options = new()
    {
        Legend = new Legend { Position = LegendPosition.Bottom },
        Colors = new List<string> { "#0F766E", "#14B8A6", "#F59E0B", "#EF4444", "#10B981", "#0D3B36" }
    };
}
