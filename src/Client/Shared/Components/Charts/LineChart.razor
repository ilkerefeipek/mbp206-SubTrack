@using ApexCharts

<div class="w-full">
    @if (!string.IsNullOrEmpty(Title))
    {
        <h3 class="text-sm font-semibold text-slate-700 mb-2">@Title</h3>
    }
    <ApexChart TItem="ChartPoint" Options="_options" Width="@Width">
        <ApexPointSeries TItem="ChartPoint"
                         Items="Data"
                         Name="@SeriesName"
                         SeriesType="@(ShowArea ? SeriesType.Area : SeriesType.Line)"
                         XValue="@(e => e.X)"
                         YValue="@(e => e.Y)" />
    </ApexChart>
</div>

@code {
    public sealed record ChartPoint(string X, decimal Y);

    [Parameter, EditorRequired] public IEnumerable<ChartPoint> Data { get; set; } = Array.Empty<ChartPoint>();
    [Parameter] public string? Title { get; set; }
    [Parameter] public string SeriesName { get; set; } = "Aylık Toplam";
    [Parameter] public bool ShowArea { get; set; } = true;
    [Parameter] public string Width { get; set; } = "100%";

    private ApexChartOptions<ChartPoint> _options = new()
    {
        Colors = new List<string> { "#0F766E" },
        Stroke = new Stroke { Curve = Curve.Smooth, Width = 3 }
    };
}
