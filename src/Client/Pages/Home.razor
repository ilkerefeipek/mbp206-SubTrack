@page "/"
@attribute [Authorize]

<PageTitle>Dashboard — SubTrack</PageTitle>

<div class="space-y-8">
    <header>
        <h1 class="text-2xl font-bold text-primary-dark tracking-tight">Dashboard</h1>
        <p class="text-sm text-slate-500 mt-1">Bu sayfa S5'te gercek verilerle dolacak. Su an iskelet gosteriliyor.</p>
    </header>

    <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
        <KpiCard Label="Aktif Abonelik" Value="—" IconName="credit-card" AccentColor="KpiCard.Accent.Primary" />
        <KpiCard Label="Aylik Harcama" Value="—" Unit="TRY" IconName="bar-chart" AccentColor="KpiCard.Accent.Success" />
        <KpiCard Label="Yakinda Yenilenecek" Value="—" IconName="bell" AccentColor="KpiCard.Accent.Warning" />
        <KpiCard Label="Kullanilmayan" Value="—" IconName="alert-circle" AccentColor="KpiCard.Accent.Danger" />
    </section>

    <Card>
        <EmptyState IconName="inbox"
                    Title="Henuz icerik yok"
                    Description="Bu kart Sprint S5'te grafikler ve yaklaşan odemeler ile dolacak." />
    </Card>
</div>
