@page "/subscriptions"
@attribute [Authorize]
@implements IDisposable
@inject ISubscriptionsApi SubscriptionsApi
@inject ICategoriesApi CategoriesApi
@inject NavigationManager Navigation
@inject IToastService Toasts

<PageTitle>Abonelikler — SubTrack</PageTitle>

<div class="space-y-6">
    <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-primary-dark tracking-tight">Aboneliklerim</h1>
            <p class="text-sm text-slate-500 mt-1">@_subscriptions.Count abonelik gosteriliyor.</p>
        </div>
        <Button Variant="Button.ButtonVariant.Primary"
                IconName="credit-card"
                OnClick="@(() => Navigation.NavigateTo("/subscriptions/new"))">
            Yeni Abonelik
        </Button>
    </header>

    <Card BodyClass="p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3">
            <div class="md:flex-1">
                <input type="search"
                       placeholder="Abonelik adina gore ara..."
                       value="@_searchInput"
                       class="w-full px-3 py-2 text-sm bg-white border border-slate-300 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
                       @oninput="OnSearchChanged" />
            </div>
            <div class="flex items-center gap-2 flex-wrap">
                <button class="@FilterChipClass(null)" @onclick="@(() => SetStatusAsync(null))">Hepsi</button>
                <button class="@FilterChipClass(SubscriptionStatus.Active)" @onclick="@(() => SetStatusAsync(SubscriptionStatus.Active))">Aktif</button>
                <button class="@FilterChipClass(SubscriptionStatus.Paused)" @onclick="@(() => SetStatusAsync(SubscriptionStatus.Paused))">Duraklatildi</button>
                <button class="@FilterChipClass(SubscriptionStatus.Cancelled)" @onclick="@(() => SetStatusAsync(SubscriptionStatus.Cancelled))">Iptal</button>
            </div>
            <div class="md:w-56">
                <Select TItem="CategoryOption" TValue="long"
                        Options="_categoryOptions"
                        DisplaySelector="@(c => c.Name)"
                        ValueSelector="@(c => c.Id)"
                        Placeholder="Tum kategoriler"
                        @bind-Value="_selectedCategoryId" />
            </div>
        </div>
    </Card>

    @if (_loading)
    {
        <Card>
            <div class="space-y-3 py-2">
                @for (var i = 0; i < 4; i++)
                {
                    <Skeleton Width="100%" Height="48px" Variant="Skeleton.Shape.Box" />
                }
            </div>
        </Card>
    }
    else if (_loadError is not null)
    {
        <Card>
            <ErrorState Title="Abonelikler yuklenemedi"
                        Description="@_loadError"
                        OnRetry="LoadAsync" />
        </Card>
    }
    else if (_subscriptions.Count == 0)
    {
        <Card>
            <EmptyState Title="Aboneliginiz yok"
                        Description="Yeni Abonelik butonuna basarak takip etmek istediginiz aboneligi ekleyin.">
                <Action>
                    <Button Variant="Button.ButtonVariant.Primary"
                            OnClick="@(() => Navigation.NavigateTo("/subscriptions/new"))">
                        Yeni Abonelik Ekle
                    </Button>
                </Action>
            </EmptyState>
        </Card>
    }
    else
    {
        @* Desktop table *@
        <div class="hidden md:block">
            <Card BodyClass="p-0">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wider">
                            <tr>
                                <th class="text-left px-4 py-3 font-semibold">Servis</th>
                                <th class="text-left px-4 py-3 font-semibold">Kategori</th>
                                <th class="text-right px-4 py-3 font-semibold">Tutar</th>
                                <th class="text-left px-4 py-3 font-semibold">Donem</th>
                                <th class="text-left px-4 py-3 font-semibold">Sonraki Odeme</th>
                                <th class="text-left px-4 py-3 font-semibold">Durum</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @foreach (var sub in _subscriptions)
                            {
                                <tr class="hover:bg-slate-50 transition">
                                    <td class="px-4 py-3 font-medium text-slate-900">@sub.Name</td>
                                    <td class="px-4 py-3 text-slate-600">@sub.CategoryName</td>
                                    <td class="px-4 py-3 text-right font-semibold text-slate-900">@Formatter.FormatCurrency(sub.Amount, sub.Currency)</td>
                                    <td class="px-4 py-3 text-slate-600">@CycleLabel(sub.BillingCycle)</td>
                                    <td class="px-4 py-3 text-slate-600">@Formatter.FormatDate(sub.NextBilling)</td>
                                    <td class="px-4 py-3">
                                        <Badge Color="@BadgeColor(sub.Status)">@StatusLabel(sub.Status)</Badge>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center justify-end gap-1">
                                            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm"
                                                    OnClick="@(() => MarkUsedAsync(sub))">
                                                Kullanildi
                                            </Button>
                                            <Button Variant="Button.ButtonVariant.Danger" Size="Button.ButtonSize.Sm"
                                                    OnClick="@(() => OpenDelete(sub))">
                                                Sil
                                            </Button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </Card>
        </div>

        @* Mobile card list *@
        <div class="md:hidden grid grid-cols-1 gap-3">
            @foreach (var sub in _subscriptions)
            {
                <Card BodyClass="p-4">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="font-semibold text-slate-900">@sub.Name</p>
                            <p class="text-xs text-slate-500 mt-0.5">@sub.CategoryName · @CycleLabel(sub.BillingCycle)</p>
                        </div>
                        <Badge Color="@BadgeColor(sub.Status)">@StatusLabel(sub.Status)</Badge>
                    </div>
                    <div class="mt-3 flex items-baseline gap-2">
                        <span class="text-lg font-bold text-primary-dark">@Formatter.FormatCurrency(sub.Amount, sub.Currency)</span>
                        <span class="text-xs text-slate-500">· @Formatter.FormatDate(sub.NextBilling) tarihinde</span>
                    </div>
                    <div class="mt-4 flex items-center gap-2">
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm"
                                OnClick="@(() => MarkUsedAsync(sub))">Kullanildi</Button>
                        <Button Variant="Button.ButtonVariant.Danger" Size="Button.ButtonSize.Sm"
                                OnClick="@(() => OpenDelete(sub))">Sil</Button>
                    </div>
                </Card>
            }
        </div>
    }
</div>

<DeleteConfirmModal IsOpen="_deleteTarget is not null"
                    Title="Aboneligi sil?"
                    Description="Bu islem geri alinamaz; abonelige bagli odemeler ve kullanim kayitlari da silinir."
                    ItemName="@_deleteTarget?.Name"
                    Working="_deleting"
                    OnConfirm="ConfirmDeleteAsync"
                    OnCancel="@(() => _deleteTarget = null)" />

@code {
    private List<SubscriptionListItemDto> _subscriptions = new();
    private List<CategoryOption> _categoryOptions = new() { new(0, "Tum kategoriler") };
    private bool _loading = true;
    private string? _loadError;

    private string _searchInput = "";
    private SubscriptionStatus? _selectedStatus;
    private long _selectedCategoryId;
    private readonly Debouncer _debouncer = new();

    private SubscriptionListItemDto? _deleteTarget;
    private bool _deleting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var cats = await CategoriesApi.ListAsync();
            _categoryOptions = new() { new(0, "Tum kategoriler") };
            _categoryOptions.AddRange(cats.Select(c => new CategoryOption(c.Id, c.Name)));
        }
        catch
        {
            // non-fatal: filter dropdown will only show "Tum kategoriler"
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            var filters = new SubscriptionFilters
            {
                CategoryId = _selectedCategoryId > 0 ? _selectedCategoryId : null,
                Status = _selectedStatus,
                Search = string.IsNullOrWhiteSpace(_searchInput) ? null : _searchInput.Trim()
            };
            _subscriptions = (await SubscriptionsApi.ListAsync(filters)).ToList();
        }
        catch (ApiException ex)
        {
            _loadError = ex.Detail ?? ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SetStatusAsync(SubscriptionStatus? status)
    {
        _selectedStatus = status;
        await LoadAsync();
    }

    private Task OnSearchChanged(ChangeEventArgs e)
    {
        _searchInput = e.Value?.ToString() ?? "";
        return _debouncer.DebounceAsync(300, async () =>
        {
            await InvokeAsync(LoadAsync);
        });
    }

    protected override async Task OnParametersSetAsync()
    {
        // Re-load when category dropdown bound value changes (Select fires ValueChanged).
        await Task.CompletedTask;
    }

    private async Task MarkUsedAsync(SubscriptionListItemDto sub)
    {
        try
        {
            await SubscriptionsApi.MarkAsUsedAsync(sub.Id);
            Toasts.ShowSuccess($"{sub.Name} kullanim tarihi guncellendi.");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Toasts.ShowError(ex.Detail ?? ex.Message);
        }
    }

    private void OpenDelete(SubscriptionListItemDto sub) => _deleteTarget = sub;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        _deleting = true;
        try
        {
            var name = _deleteTarget.Name;
            await SubscriptionsApi.DeleteAsync(_deleteTarget.Id);
            _deleteTarget = null;
            Toasts.ShowSuccess($"{name} silindi.");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Toasts.ShowError(ex.Detail ?? ex.Message);
        }
        finally
        {
            _deleting = false;
        }
    }

    private string FilterChipClass(SubscriptionStatus? status)
    {
        var active = _selectedStatus == status;
        return active
            ? "px-3 py-1.5 text-xs font-semibold rounded-full bg-primary text-white transition focus:outline-none focus-visible:ring-2 ring-primary/40"
            : "px-3 py-1.5 text-xs font-medium rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 transition focus:outline-none focus-visible:ring-2 ring-primary/40";
    }

    private static string StatusLabel(SubscriptionStatus s) => s switch
    {
        SubscriptionStatus.Active => "Aktif",
        SubscriptionStatus.Paused => "Duraklatildi",
        SubscriptionStatus.Cancelled => "Iptal",
        _ => s.ToString()
    };

    private static Badge.Variant BadgeColor(SubscriptionStatus s) => s switch
    {
        SubscriptionStatus.Active => Badge.Variant.Success,
        SubscriptionStatus.Paused => Badge.Variant.Warning,
        SubscriptionStatus.Cancelled => Badge.Variant.Neutral,
        _ => Badge.Variant.Neutral
    };

    private static string CycleLabel(BillingCycle c) => c switch
    {
        BillingCycle.Weekly => "Haftalik",
        BillingCycle.Monthly => "Aylik",
        BillingCycle.Quarterly => "3 Aylik",
        BillingCycle.Yearly => "Yillik",
        _ => c.ToString()
    };

    public void Dispose() => _debouncer.Dispose();

    private sealed record CategoryOption(long Id, string Name);
}
