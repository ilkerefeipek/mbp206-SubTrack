@page "/analytics"
@attribute [Authorize]

<PageTitle>Analiz — SubTrack</PageTitle>

<div class="space-y-6">
    <header>
        <h1 class="text-2xl font-bold text-primary-dark tracking-tight">Analiz</h1>
        <p class="text-sm text-slate-500 mt-1">12 aylik trend, kategori dagilimi ve kullanilmayan abonelikler — S5'te.</p>
    </header>
    <Card>
        <EmptyState IconName="bar-chart"
                    Title="Grafikler bekleniyor"
                    Description="Sprint S5: aylik trend cizgi grafigi, kategori pasta dilimi, kullanilmayan abonelik listesi + insight'lar." />
    </Card>
</div>
